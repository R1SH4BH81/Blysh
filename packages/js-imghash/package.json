{
  "name": "blysh",
  "version": "1.0.0",
  "description": "High-performance visual hashing for seamless image loading. Encode images into tiny strings and decode into beautiful, fast-loading blurs.",
  "main": "./dist/imghash.js",
  "module": "./dist/imghash.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/imghash.mjs",
      "require": "./dist/imghash.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/R1SH4BH81/ImgHash.git"
  },
  "homepage": "https://img-hash.vercel.app",
  "bugs": {
    "url": "https://img-hash.vercel.app/issues"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "imghash",
    "blurhash",
    "placeholder",
    "progressive-loading",
    "image-performance",
    "react",
    "typescript",
    "nextjs"
  ],
  "author": "Rishabh Mishra <rishabhmishra.81@gmail.com>",
  "license": "MIT"
}